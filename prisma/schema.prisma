// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Domain {
  id             String   @id @default(uuid())
  domain         String
  domainPriority String   @default("3 - Maintenance") // "1 - Critical" | "2 - Important" | "3 - Maintenance"
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  tasks          Task[]
}

model Task {
  id            String    @id @default(uuid())
  taskName      String
  status        String    @default("Backlog") // "Needs Details" | "Backlog" | "Blocked" | "Done" | "Archived"
  taskPriority  String    @default("3 - Normal") // "1 - Urgent" | "2 - High" | "3 - Normal" | "4 - Low" | "5 - Optional"
  dueDate       DateTime?
  plannedDate   DateTime?
  recurrence    String    @default("None") // "None" | "Daily" | "Weekly" | "Biweekly" | "Monthly" | "Quarterly" | "Yearly"
  lastCompleted DateTime?
  actionPoints  Int?
  notes         String?
  domainId      String?
  domain        Domain?   @relation(fields: [domainId], references: [id], onDelete: SetNull)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}
